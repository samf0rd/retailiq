# Caddyfile
# Caddy auto-provisions and renews Let's Encrypt certs for this domain the
# moment it can see it publicly on port 80/443 — no manual cert steps.
# Requirement: retailiq.samvgarcia.com's DNS A record must point at this
# server's IP BEFORE Caddy first starts, or the ACME challenge fails.

retailiq.samvgarcia.com {
    # FastAPI routes live under /api/* — proxy those to the api container.
    handle /api/* {
        reverse_proxy api:8000
    }

    # Everything else goes to the Next.js dashboard.
    handle {
        reverse_proxy dashboard:3000
    }

    encode gzip

    log {
        output file /data/access.log
    }
}
